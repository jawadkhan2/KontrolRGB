{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KontrolRGB",
  "version": "0.2.3",
  "identifier": "com.jawad.kontrolrgb",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "KontrolRGB",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "theme": "Dark",
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; connect-src ipc: http://ipc.localhost http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jawadkhan2/KontrolRGB/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyOTIxNUY1NEFFRkRCRDIKUldUUzIrOUs5UldTTWdBU2Y5OGhFMjl6R3dFbjIzaW13djVkSWFhcHZVUmdEY0pLM0dURlRRdSsK"
    }
  }
}
